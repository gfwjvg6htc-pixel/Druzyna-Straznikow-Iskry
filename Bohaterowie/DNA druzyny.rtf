\pard\pardeftab720\partightenfactor0

\f2\fs26\fsmilli13333 \cf2 Aura jest \'84od Wiatru\'94, poniewa\uc0\u380  nigdy nie stoi w miejscu i odwa\u380 nie robi pierwszy krok, wprawiaj\u261 c \u347 wiat i innych w ruch.
\f1\fs32 \

\f2\fs26\fsmilli13333 Rowan jest \'84od Drewna\'94, poniewa\uc0\u380  daje innym oparcie, cierpliwie naprawia to, co zosta\u322 o zepsute, i wierzy, \u380 e \u347 wiat zawsze mo\u380 na uczyni\u263  odrobin\u281  lepszym.
\f1\fs32 \

\f2\fs26\fsmilli13333 Iris jest \'84od Kwiat\'f3w\'94, poniewa\uc0\u380  dostrzega dobro i pi\u281 kno w innych oraz pomaga im rozkwita\u263 .
\f1\fs32 \

\f2\fs26\fsmilli13333 Echo jest \'84od \uc0\u346 wiat\u322 a\'94, poniewa\u380  wnosi s\u322 o\u324 ce, lekko\u347 \u263 , nadziej\u281  i rado\u347 \u263  nawet wtedy, gdy innym wydaje si\u281 , \u380 e wszystko jest ju\u380  stracone.
\f1\fs32 \

\f2\fs26\fsmilli13333 Nox jest \'84od Gwiazd\'94, poniewa\uc0\u380  patrzy dalej ni\u380  inni,\'a0Jak zostawi\u263  \u347 wiat lepszym, ni\u380  si\u281  go zasta\u322 o?
\f1\fs32 \

\f2\fs26\fsmilli13333 \'a0
\f1\fs32 \
